# Network — mainnet (Base) or testnet (Base Sepolia)
# Use testnet for free testing via https://faucet.circle.com (20 USDC / 2h)
# Use mainnet for production / live demo
NETWORK=mainnet

# Circle Agent Stack
# Auth is via Circle CLI (email + OTP) — NO API key needed here.
# One-time setup: npm i -g @circle-fin/cli → login → create wallet
# CIRCLE_CLI_HOME=           # optional: override default ~/.circle
AGENT_SPEND_BUDGET_USDC=5   # per-run spend cap in USDC

# Agent wallet address (set after Circle CLI wallet creation)
AGENT_WALLET_ADDRESS=

# Anthropic — Claude Agent SDK uses API key auth only (not OAuth)
ANTHROPIC_API_KEY=
# LLM_MODEL=                # optional, default: claude-sonnet-4-6

# x402 facilitator (Coinbase-hosted, do not change)
X402_FACILITATOR_URL=https://x402.org/facilitator

# Nebius Token Factory — must be direct, NOT via OpenRouter
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_API_KEY=

# Tavily
TAVILY_API_KEY=

# OOBE Synapse RPC (x402-powered data layer)
SYNAPSE_RPC_URL=

# Block explorer URL — exposed to browser for receipt links
# mainnet: https://basescan.org  |  testnet: https://sepolia.basescan.org
NEXT_PUBLIC_BLOCK_EXPLORER=https://basescan.org

# Demo mode — bypasses all live API/payment calls, returns data/mock_brief.json
USE_MOCK=true
